        if setting[4] == "checkbox" then
            local checkbox = Instance.new("TextButton")
            checkbox.Size = UDim2.new(0.08, 0, 0, 30)
            checkbox.Position = UDim2.new(0.65, 0, 0, y)
            checkbox.BackgroundColor3 = Config[setting[2]] and Color3.fromRGB(0,150,0) or Color3.fromRGB(60,60,70)
            checkbox.Text = Config[setting[2]] and "✓" or ""
            checkbox.Font = Enum.Font.GothamBold
            checkbox.TextScaled = true
            checkbox.TextColor3 = Color3.new(1,1,1)
            Parent(checkbox, MainScroll)
            Round(checkbox, 4)
            checkbox.MouseButton1Click:Connect(function()
                Config[setting[2]] = not Config[setting[2]]
                checkbox.BackgroundColor3 = Config[setting[2]] and Color3.fromRGB(0,150,0) or Color3.fromRGB(60,60,70)
                checkbox.Text = Config[setting[2]] and "✓" or ""
            end)
        else
            local box = Instance.new("TextBox")
            box.Size = UDim2.new(0.3, 0, 0, 30)
            box.Position = UDim2.new(0.65, 0, 0, y)
            box.BackgroundColor3 = Color3.fromRGB(60,60,70)
            box.TextColor3 = Color3.new(1,1,1)
            box.Font = Enum.Font.Gotham
            box.TextScaled = true
            box.Text = tostring(Config[setting[2]])
            Parent(box, MainScroll)
            box.FocusLost:Connect(function(enter)
                if enter then
                    local num = tonumber(box.Text)
                    if num then
                        Config[setting[2]] = num
                    else
                        box.Text = tostring(Config[setting[2]])
                    end
                end
            end)
        end
        y = y + 35
    end
end

-- ===== 碰撞处理 =====
local OriginalCollisions = {}
local function SaveCollisions()
    OriginalCollisions = {}
    if Character then
        for _, part in pairs(Character:GetDescendants()) do
            if part:IsA("BasePart") then
                OriginalCollisions[part] = part.CanCollide
            end
        end
    end
end
local function DisableCollisions()
    if not Config.AllowInvisible then return end
    for part, _ in pairs(OriginalCollisions) do
        if part and part.Parent then
            if part == Character:FindFirstChild("HumanoidRootPart") then
                part.CanCollide = true
            else
                part.CanCollide = false
            end
        end
    end
end
local function RestoreCollisions()
    for part, canCollide in pairs(OriginalCollisions) do
        if part and part.Parent then
            part.CanCollide = canCollide
        end
    end
end
SaveCollisions()
local CollisionConn
CollisionConn = RunService.Stepped:Connect(function()
    if Character and Character.Parent then
        if Config.AllowInvisible then
            DisableCollisions()
        else
            RestoreCollisions()
        end
    else
        RestoreCollisions()
        if CollisionConn then
            CollisionConn:Disconnect()
        end
    end
end)
Player.CharacterAdded:Connect(function(newChar)
    RestoreCollisions()
    Character = newChar
    Humanoid = newChar:WaitForChild("Humanoid")
    SaveCollisions()
    if CollisionConn then CollisionConn:Disconnect() end
    CollisionConn = RunService.Stepped:Connect(function()
        if Character and Character.Parent then
            if Config.AllowInvisible then
                DisableCollisions()
            else
                RestoreCollisions()
            end
        else
            RestoreCollisions()
            if CollisionConn then CollisionConn:Disconnect() end
        end
    end)
end)

