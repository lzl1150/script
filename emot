local function SwitchTab(tabIndex)
    CurrentTab = tabIndex
    -- 隐藏所有标签页的专用控件
    SearchBox.Visible = (tabIndex == 1)
    SortBtn.Visible = (tabIndex == 1)
    RefreshBtn.Visible = (tabIndex == 1)
    PrevBtn.Visible = (tabIndex == 1)
    NextBtn.Visible = (tabIndex == 1)
    PageBox.Visible = (tabIndex == 1)

    AnimSearchBox.Visible = (tabIndex == 3)
    AnimSortBtn.Visible = (tabIndex == 3)
    AnimModeBtn.Visible = (tabIndex == 3)
    AnimPrevBtn.Visible = (tabIndex == 3)
    AnimNextBtn.Visible = (tabIndex == 3)
    AnimPageBox.Visible = (tabIndex == 3)

    -- 更新标签按钮颜色
    for i, btn in pairs(Tabs) do
        if i == tabIndex then
            btn.BackgroundColor3 = Color3.fromRGB(60, 120, 80)
        else
            btn.BackgroundColor3 = Color3.fromRGB(40, 50, 60)
        end
    end

    -- 显示对应内容
    if tabIndex == 1 then
        ShowCatalogPage()
    elseif tabIndex == 2 then
        ShowSavedPage()
    elseif tabIndex == 3 then
        ShowAnimationsPage()
    elseif tabIndex == 4 then
        ShowSettingsPage()
    end
end

