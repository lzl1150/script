-- 工具函数
local function Round(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius)
    c.Parent = obj
end
local function Border(obj, color, size)
    local f = Instance.new("Frame")
    f.Size = UDim2.new(1, 0, 1, 0)
    f.BackgroundTransparency = 1
    f.BorderSizePixel = 0
    f.ZIndex = obj.ZIndex + 1
    f.Parent = obj
    local s = Instance.new("UIStroke")
    s.Color = color
    s.Thickness = size or 1
    s.Parent = f
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, size or 1)
    c.Parent = f
    return f
end
local function Parent(obj, parent)
    obj.Parent = parent
end
local function sz(x, y)
    return UDim2.new(0, x or 0, 0, y or 0)
end

