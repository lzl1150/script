-- ==================== 分页逻辑 ====================

local isLoading = false

-- 显示某一页
local function showPage(pages)
    if isLoading then return end
    isLoading = true

    pageBox.Text = "Loading..."
    RunService.RenderStepped:Wait()

    -- 清空当前卡片
    for _, child in ipairs(emotesScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local currentList = nil
    local ok, items = pcall(function()
        return pages:GetCurrentPage()
    end)
    if ok then
        currentList = items
    else
        pageBox.Text = "ERROR"
        isLoading = false
        return
    end

    if currentList and #currentList > 0 then
        emptyLabel.Visible = false
        for _, item in ipairs(currentList) do
            local card = createEmoteCard(item)
            card.Parent = emotesScroll
        end
    else
        emptyLabel.Text = "No results found"
        emptyLabel.Visible = true
    end

    -- 更新画布大小
    emotesScroll.CanvasSize = UDim2.new(0, 0, 0, emotesLayout.AbsoluteContentSize.Y + 8)

    -- 更新页码显示
    pageBox.Text = tostring(currentPageNumber) .. " / Enter page"
    updateNavVisibility()

    isLoading = false
end

-- 跳转到指定页
local function fetchPageTo(targetPage)
    local pages = getPages(currentKeyword)
    if not pages then return nil end
    for i = 2, targetPage do
        if pages.IsFinished then break end
        local ok, err = pcall(function()
            pages:AdvanceToNextPageAsync()
        end)
        if not ok then break end
    end
    return pages
end

-- 发起新搜索
local function doNewSearch(keyword)
    currentKeyword = keyword or ""
    currentPageNumber = 1
    pageBox.Text = "Loading..."

    currentPages = getPages(currentKeyword)
    if currentPages then
        showPage(currentPages)
    end
end

