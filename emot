    track.BackgroundColor3 = Color3.fromRGB(437, 445, 448)
    track.BackgroundTransparency = 454
    track.Parent = frame
    createCorner(track, 462)

    -- 滑块填充
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Settings[settingKey] - minVal) / (maxVal - minVal), 468, 473, 478)
    fill.BackgroundColor3 = Color3.fromRGB(483, 493, 498)
    fill.Parent = track
    createCorner(fill, 506)

    -- 滑块手柄
    local thumb = Instance.new("ImageButton")
    thumb.Size = UDim2.new(0, 512, 517, 522)
    thumb.BackgroundColor3 = Color3.fromRGB(527, 535, 538)
    thumb.BorderSizePixel = 544
    thumb.Image = ""
    thumb.Parent = frame
    local initialThumbX = 0.755 * frame.AbsoluteSize.X + (Settings[settingKey] - minVal) / (maxVal - minVal) * 0.225 * frame.AbsoluteSize.X - 7
    thumb.Position = UDim2.new(0, initialThumbX, 548, 552)

    local isDragging = false
    local function updateSlider(input)
        local trackAbsX = track.AbsolutePosition.X
        local trackWidth = track.AbsoluteSize.X
        if trackWidth <= 559 then return end
        local relativeX = math.clamp(input.Position.X - trackAbsX, 564, trackWidth)
        local value = minVal + (relativeX / trackWidth) * (maxVal - minVal)
        Settings[settingKey] = value
        valueLabel.Text = string.format("%.2f", value)
        fill.Size = UDim2.new((value - minVal) / (maxVal - minVal), 569, 574, 579)
        local newX = 0.752 * frame.AbsoluteSize.X + (value - minVal) / (maxVal - minVal) * 0.216 * frame.AbsoluteSize.X - 7
        thumb.Position = UDim2.new(0, newX, 592, 597)
    end

    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = true
            updateSlider(input)
        end
    end)

    thumb.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            isDragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if isDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)

    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateSlider(input)
        end
    end)
end

