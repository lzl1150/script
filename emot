    {Enum.CatalogSortType.PriceHighToLow, "Price: High→Low"},
}

-- 搜索 Emote（不使用 Offset，改用 Pages 翻页）
local function SearchCatalogEmotes(keyword, sortIdx, page)
    local params = CatalogSearchParams.new()
    params.SearchKeyword = keyword or ""
    params.AssetTypes = {Enum.AvatarAssetType.EmoteAnimation}
    params.IncludeOffSale = true
    params.SortType = CatalogSortModes[sortIdx][1]
    params.Limit = 24

    local ok, pages = pcall(function()
        return AvatarEditorService:SearchCatalog(params)
    end)
    if not ok or not pages then return nil end

    -- 翻到目标页（Pages 只能前进，不能后退）
    for i = 2, page do
        local success, err = pcall(function()
            pages:AdvanceToNextPageAsync()
        end)
        if not success then break end
    end
    return pages:GetCurrentPage()
end

-- 显示 Catalog 页面
local function ShowCatalogPage()
    for _, child in pairs(MainScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local items = SearchCatalogEmotes(CatalogKeyword, CatalogSortIdx, CatalogPage)
    if not items or #items == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1,0,0,40)
        empty.BackgroundTransparency = 1
        empty.Text = "No emotes found. Try different keywords."
        empty.TextColor3 = Color3.new(0.7,0.7,0.7)
        empty.Font = Enum.Font.Gotham
        empty.TextScaled = true
        Parent(empty, MainScroll)
        return
    end
    for _, item in ipairs(items) do
        local card = CreateItemCard({Id = item.Id, Name = item.Name, IsBundle = false})
        Parent(card, MainScroll)
    end
end

