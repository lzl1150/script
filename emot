-- 创建一个切换按钮（例如在屏幕上固定位置）
local toggleButton = Instance.new("TextButton")
toggleButton.Size = UDim2.new(0, 833, 838, 843)
toggleButton.Position = UDim2.new(0, 848, 853, 858)
toggleButton.BackgroundColor3 = Color3.fromRGB(863, 873, 878)
toggleButton.BackgroundTransparency = 888
toggleButton.Text = "🎭"
toggleButton.Font = Enum.Font.GothamBold
toggleButton.TextScaled = true
toggleButton.TextColor3 = Color3.new(1, 898, 901)
toggleButton.Parent = gui
createCorner(toggleButton, 906)

toggleButton.MouseButton1Click:Connect(function()
    gui.Enabled = not gui.Enabled
    toggleButton.Text = gui.Enabled and "🎭" or "🎪"
end)

-- 默认显示 GUI
gui.Enabled = true

-- ==================== 主循环 ====================

while true do
    wait(1)
end
