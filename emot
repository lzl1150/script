-- 保存函数
local function SaveEmote(data)
    for _, saved in ipairs(SavedEmotes) do
        if saved.Id == data.Id and saved.IsBundle == data.IsBundle then
            return false
        end
    end
    table.insert(SavedEmotes, data)
    return true
end

local function RemoveEmote(index)
    table.remove(SavedEmotes, index)
end

-- 显示 Saved 页面
local function ShowSavedPage()
    for _, child in pairs(MainScroll:GetChildren()) do
