-- ==================== 基础工具 ====================

local Screen = setmetatable({}, {
    __index = function(self, key)
        local cam = workspace.CurrentCamera
        local size = cam and cam.ViewportSize or Vector2.new(1920, 1080)
        if key == "Width" then return size.X
        elseif key == "Height" then return size.Y
        elseif key == "Size" then return size end
    end
})

local UserInputService = game:GetService("UserInputService")
local ViewportSize = workspace.CurrentCamera.ViewportSize

-- 根据屏幕尺寸缩放数值（适配移动端/桌面）
local function scale(axis, value)
    local isMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    local baseWidth, baseHeight = 1920, 1080
    local scaleFactor = isMobile and 2 or 1.5
    if axis == "X" then
        return value * (ViewportSize.X / baseWidth) * scaleFactor
    elseif axis == "Y" then
        return value * (ViewportSize.Y / baseHeight) * scaleFactor
    end
end

-- 安全调用函数（兼容不同执行环境）
local function safeCall(typeCheck, func, fallback)
    if type(func) == typeCheck then return func end
    return fallback
end

