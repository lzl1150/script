-- 播放函数
local function PlayAnimation(assetId, looped)
    looped = looped or false
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. assetId
    local animator = Humanoid:FindFirstChildOfClass("Animator")
    if not animator then
        animator = Instance.new("Animator")
        animator.Parent = Humanoid
    end
    for _, track in pairs(animator:GetPlayingAnimationTracks()) do
        if track.Name == tostring(assetId) then
            track:Stop()
            track:Destroy()
        end
    end
    local track = animator:LoadAnimation(anim)
    track.Looped = looped
    track.Priority = Config.HighPriority and Enum.AnimationPriority.Action or Enum.AnimationPriority.Idle
    track:AdjustSpeed(Config.Speed)
    track:AdjustWeight(Config.Weight)
    track.TimePosition = Config.TimePosition
    track:Play(Config.FadeIn, Config.FadeOut)
    track.Name = tostring(assetId)
    return track
end

-- 通用卡片创建函数
local function CreateItemCard(data)
    -- data: {Id, Name, IsBundle}
    local card = Instance.new("Frame")
    card.Size = sz(120, 180)
    card.BackgroundColor3 = Color3.fromRGB(25, 25, 35)
    card.BackgroundTransparency = 0.2
    Round(card, 8)
    Border(card, Color3.fromRGB(60,60,90), 1)

    local thumb = Instance.new("ImageLabel")
    thumb.Size = UDim2.new(1, -10, 0, 90)
    thumb.Position = UDim2.new(0, 5, 0, 5)
    thumb.BackgroundTransparency = 1
    thumb.ScaleType = Enum.ScaleType.Fit
    local idStr = tostring(data.Id)
    if data.IsBundle then
        thumb.Image = "rbxthumb://type=BundleThumbnail&id=" .. idStr .. "&w=150&h=150"
    else
        thumb.Image = "rbxthumb://type=Asset&id=" .. idStr .. "&w=150&h=150"
    end
    Parent(thumb, card)
    Round(thumb, 4)

    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, -10, 0, 28)
    nameLabel.Position = UDim2.new(0, 5, 0, 100)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = (data.IsBundle and "📦 " or "") .. (data.Name or "Unknown")
    nameLabel.TextScaled = true
    nameLabel.TextWrapped = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextColor3 = Color3.new(1,1,1)
    Parent(nameLabel, card)

    -- 使用按钮
    local playBtn = Instance.new("TextButton")
    playBtn.Size = UDim2.new(0.9, 0, 0, 26)
    playBtn.Position = UDim2.new(0.05, 0, 1, -30)
    playBtn.BackgroundColor3 = Color3.fromRGB(40, 140, 80)
    playBtn.BackgroundTransparency = 0.2
    playBtn.Text = data.IsBundle and "Preview" or "Play"
    playBtn.Font = Enum.Font.GothamBold
    playBtn.TextScaled = true
    playBtn.TextColor3 = Color3.new(1,1,1)
    Parent(playBtn, card)
    Round(playBtn, 4)

    playBtn.MouseButton1Click:Connect(function()
        if data.IsBundle then
            local ok, bundle = pcall(function()
                return AssetService:GetBundleDetailsAsync(data.Id)
            end)
            if ok and bundle then
                local items = bundle.Items or bundle.BundledItems or {}
                local targetId
                for _, item in ipairs(items) do
                    if item.AssetType and (item.AssetType:find("Run") or item.AssetType:find("Walk") or item.AssetType:find("Idle")) then
                        targetId = tonumber(item.Id)
                        if item.AssetType:find("Run") then break end
                    end
                end
                if targetId then
                    PlayAnimation(targetId, true)
                    playBtn.Text = "▶ Playing"
                    task.delay(1.5, function() playBtn.Text = "Preview" end)
                else
                    playBtn.Text = "No anim"
                end
            else
                playBtn.Text = "Fail"
            end
        else
            PlayAnimation(data.Id, false)
        end
    end)

    -- 复制链接按钮
    local copyBtn = Instance.new("TextButton")
    copyBtn.Size = sz(36, 36)
    copyBtn.Position = UDim2.new(1, -42, 0, 5)
    copyBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 45)
    copyBtn.BackgroundTransparency = 0.2
    copyBtn.Text = "🔗"
    copyBtn.Font = Enum.Font.GothamBold
    copyBtn.TextScaled = true
    copyBtn.TextColor3 = Color3.new(1,1,1)
    copyBtn.AutoButtonColor = false
    Parent(copyBtn, card)
    Round(copyBtn, 6)
    copyBtn.MouseButton1Click:Connect(function()
        local link = data.IsBundle and ("https://www.roblox.com/bundles/" .. data.Id) or ("https://www.roblox.com/catalog/" .. data.Id)
        setclipboard(link)
        copyBtn.Text = "✅"
        task.wait(0.7)
        copyBtn.Text = "🔗"
    end)

    return card
end

