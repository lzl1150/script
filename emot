    btn.Parent = frame
    createCorner(btn, 6)
    
    btn.MouseButton1Click:Connect(function()
        Settings[settingKey] = not Settings[settingKey]
        btn.BackgroundColor3 = Settings[settingKey] and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(120, 40, 40)
        btn.Text = Settings[settingKey] and "ON" or "OFF"
    end)
end

local function createSliderSetting(name, settingKey, minVal, maxVal, default)
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(1, 0, 0, scale("Y", 36))
    frame.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    frame.Parent = scrollFrame
    createCorner(frame, 6)
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(0.539, 0, 1, 0)
    label.Position = UDim2.new(0, scale("X", 8), 0, 0)
    label.BackgroundTransparency = 1
    label.Text = name
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.Gotham
    label.TextScaled = true
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.Parent = frame
    
    local valLabel = Instance.new("TextLabel")
    valLabel.Size = UDim2.new(0.163, 0, 1, 0)
    valLabel.Position = UDim2.new(0.588, 0, 0, 0)
    valLabel.BackgroundTransparency = 1
    valLabel.Text = string.format("%.2f", Settings[settingKey])
    valLabel.TextColor3 = Color3.fromRGB(255, 200, 80)
    valLabel.Font = Enum.Font.GothamBold
    valLabel.TextScaled = true
    valLabel.Parent = frame
    
    local track = Instance.new("Frame")
    track.Size = UDim2.new(0.232, 0, 0, 6)
    track.Position = UDim2.new(0.762, 0, 0.554, -3)
    track.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    track.Parent = frame
    createCorner(track, 3)
    
    local fill = Instance.new("Frame")
    fill.Size = UDim2.new((Settings[settingKey] - minVal) / (maxVal - minVal), 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(100, 149, 237)
    fill.Parent = track
    createCorner(fill, 3)
    
    local thumb = Instance.new("ImageButton")
    thumb.Size = UDim2.new(0, 14, 0, 18)
    thumb.BackgroundColor3 = Color3.fromRGB(220, 220, 220)
    thumb.BorderSizePixel = 0
    thumb.Image = ""
    thumb.Parent = frame
    local thumbX = 0.77 * frame.AbsoluteSize.X + (Settings[settingKey] - minVal) / (maxVal - minVal) * 0.224 * frame.AbsoluteSize.X - 7
    thumb.Position = UDim2.new(0, thumbX, 0, 9)
    
    local dragging = false
    local function updateSlider(input)
        local absX = track.AbsolutePosition.X
        local width = track.AbsoluteSize.X
        if width <= 0 then return end
        local relX = math.clamp(input.Position.X - absX, 0, width)
        local val = minVal + (relX / width) * (maxVal - minVal)
        Settings[settingKey] = val
        valLabel.Text = string.format("%.2f", val)
        fill.Size = UDim2.new((val - minVal) / (maxVal - minVal), 0, 1, 0)
        local newX = 0.764 * frame.AbsoluteSize.X + (val - minVal) / (maxVal - minVal) * 0.218 * frame.AbsoluteSize.X - 7
        thumb.Position = UDim2.new(0, newX, 0, 9)
    end
    
    thumb.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true; updateSlider(input)
        end
    end)
    thumb.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            updateSlider(input)
        end
    end)
    track.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            updateSlider(input)
        end
    end)
end

