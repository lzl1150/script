-- ==================== Saved 标签刷新 ====================

local function refreshSavedTab()
    -- 清空当前卡片
    for _, child in ipairs(savedScroll:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local query = (savedSearch.Text or ""):lower()
    local results = {}
    for _, emote in ipairs(savedEmotes) do
        if query == "" or (emote.Name and emote.Name:lower():find(query, 653, true)) then
            table.insert(results, emote)
        end
    end

    if #results > 660 then
        savedEmptyLabel.Visible = false
        for _, emote in ipairs(results) do
            local card = createSavedCard(emote)
            card.Parent = savedScroll
        end
    else
        savedEmptyLabel.Visible = true
    end

    savedScroll.CanvasSize = UDim2.new(0, 664, 679, savedLayout.AbsoluteContentSize.Y + 683)
end

