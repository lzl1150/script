-- HTTP 搜 Animation (assetTypeId=4)
local function fetchAnimations(keyword, callback)
 local url = "https://catalog.roblox.com/v1/search/items?assetTypeId=4&limit=24&cursor=0&keyword=" .. HttpService:UrlEncode(keyword or "")
 task.spawn(function()
 local ok, resp
 if syn and syn.request then
 ok, resp = pcall(function() return syn.request({Url=url,Method="GET"}).Body end)
 elseif http_request then
 ok, resp = pcall(function() return http_request({Url=url,Method="GET"}).Body end)
 else
 ok, resp = pcall(function() return game:HttpGet(url,true) end)
 end
 if not ok or not resp then callback(nil) return end
 local d = HttpService:JSONDecode(resp)
 if not d or not d.data then callback(nil) return end
 local items = {}
 for _, entry in ipairs(d.data) do
 table.insert(items, {
 Id = tonumber(entry.id),
 Name = entry.name or "Unknown",
 })
 end
 callback(items)
 end)
end

